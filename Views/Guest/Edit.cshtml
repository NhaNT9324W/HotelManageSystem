@model HotelManageSystem.Models.Guest

@* MAPPED: [Use Case: UC15.3 - Edit Guest Profile]
    TÁC NHÂN: Receptionist (Lễ tân hiệu chỉnh dữ liệu)
*@

@{
    ViewData["Title"] = "Sửa Hồ Sơ Khách";
}

<div class="container mt-4" style="max-width: 700px;">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">✏️ Hiệu Chỉnh Thông Tin Hồ Sơ Khách Hàng</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                
                @* Các trường dữ liệu ẩn bắt buộc truyền về hàm POST để bảo toàn dữ liệu đồng bộ cấu trúc *@
                <input type="hidden" asp-for="GuestId" />
                <input type="hidden" asp-for="CreatedAt" />

                <div class="mb-3">
                    <label class="form-label">Mã Định Danh Khách Hàng (System-generated ID)</label>
                    <input class="form-control" value="@Model.GuestId" readonly style="background-color: #e9ecef;" />
                    <small class="text-danger">🔒 Luật BR-25: Mã ID do hệ thống tự sinh tự động để quản lý, không cho phép can thiệp chỉnh sửa gán tay.</small>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FullName" class="form-label">Họ và Tên Khách Hàng</label>
                        <input asp-for="FullName" class="form-control" required />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Gender" class="form-label">Giới Tính</label>
                        <select asp-for="Gender" class="form-select">
                            <option value="Male">Male (Nam)</option>
                            <option value="Female">Female (Nữ)</option>
                            <option value="Other">Other (Khác)</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="DateOfBirth" class="form-label">Ngày Sinh</label>
                        <input asp-for="DateOfBirth" type="date" class="form-control" />
                        <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Nationality" class="form-label">Quốc Tịch</label>
                        <input asp-for="Nationality" class="form-control" />
                        <span asp-validation-for="Nationality" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="IdentityNumber" class="form-label">Số CMND / CCCD / Passport (Bản gốc)</label>
                    <input asp-for="IdentityNumber" class="form-control" placeholder="Nhập dãy số định danh mới..." />
                    <span asp-validation-for="IdentityNumber" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label">Số Điện Thoại Liên Hệ</label>
                        <input asp-for="Phone" type="tel" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label">Địa Chỉ Email</label>
                        <input asp-for="Email" type="email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label">Địa Chỉ Thường Trú</label>
                    <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-secondary">🔙 Hủy thay đổi</a>
                    <button type="submit" class="btn btn-warning">💾 Lưu Cập Nhật</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}