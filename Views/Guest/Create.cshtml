@model HotelManageSystem.Models.Guest

@* MAPPED: [Use Case: UC15.1 - Create Guest Information]
    TÁC NHÂN: Receptionist (Lễ tân nhập liệu)
*@

@{
    ViewData["Title"] = "Lập Hồ Sơ Khách Mới";
}

<div class="container mt-4" style="max-width: 700px;">
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0">➕ Lập Hồ Sơ Khách Hàng Lưu Trú Mới</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                @* Hiển thị thông báo vi phạm luật BR-22 (Thiếu cả phone lẫn email) từ Controller tung lên *@
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 font-weight-bold"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FullName" class="form-label">Họ và Tên Khách Hàng</label>
                        <input asp-for="FullName" class="form-control" required placeholder="Nhập tên đầy đủ (BR-22)..." />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Gender" class="form-label">Giới Tính</label>
                        <select asp-for="Gender" class="form-select">
                            <option value="Male">Male (Nam)</option>
                            <option value="Female">Female (Nữ)</option>
                            <option value="Other">Other (Khác)</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="DateOfBirth" class="form-label">Ngày Tháng Năm Sinh</label>
                        <input asp-for="DateOfBirth" type="date" class="form-control" />
                        <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Nationality" class="form-label">Quốc Tịch</label>
                        <input asp-for="Nationality" class="form-control" value="Việt Nam" placeholder="Nhập quốc tịch..." />
                        <span asp-validation-for="Nationality" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="IdentityNumber" class="form-label">Số CMND / CCCD / Passport</label>
                    <input asp-for="IdentityNumber" class="form-control" placeholder="Nhập số định danh pháp lý của khách..." />
                    <small class="text-muted">🔒 Số này sẽ được tự động mã hóa bảo mật dấu sao (*) khi hiển thị ở bảng chung để bảo vệ quyền riêng tư cá nhân (BR-12).</small>
                    <span asp-validation-for="IdentityNumber" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label">Số Điện Thoại</label>
                        <input asp-for="Phone" type="tel" class="form-control" placeholder="09xxxxxxxx" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label">Địa Chỉ Email</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="khachhang@@gmail.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3 text-muted" style="font-size: 0.9rem;">
                    💡 <strong>Ràng buộc kinh doanh BR-22:</strong> Hệ thống bắt buộc phải điền Họ tên và có ít nhất 1 phương thức liên hệ (Số điện thoại hoặc Email) để liên lạc khi cần.
                </div>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label">Địa Chỉ Thường Trú</label>
                    <textarea asp-for="Address" class="form-control" rows="2" placeholder="Số nhà, tên đường, phường/xã, tỉnh thành..."></textarea>
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-secondary">🔙 Hủy bỏ và quay lại</a>
                    <button type="submit" class="btn btn-success">💾 Ghi Nhận Hồ Sơ</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}