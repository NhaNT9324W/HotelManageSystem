@model IEnumerable<HotelManageSystem.Models.Account>

@* MAPPED: [Use Case: UC5.4 - View List Account] & [Use Case: UC5.5 - Search Account]
    TÁC NHÂN: Admin (Admin Rights / Root Access)
*@

@{
    ViewData["Title"] = "Quản Lý Tài Khoản Nhân Viên";
}

<div class="container mt-4">
    <h2>📋 Quản Lý Danh Sách Tài Khoản</h2>
    <hr />

    @* Hiển thị thông báo lỗi hệ thống nếu Admin vi phạm quy tắc bảo vệ chống tự sát tài khoản (BR-11) *@
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>⚠️ Lỗi Nghiệp Vụ:</strong> @TempData["ErrorMessage"]
        </div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-6">
                    <input type="text" name="searchKeyword" class="form-control" 
                           placeholder="Tìm theo Username, Email hoặc Số điện thoại..." 
                           value="@ViewData["CurrentSearch"]" />
                </div>
                <div class="col-md-4">
                    <select name="roleId" class="form-select" asp-items="ViewBag.RolesList">
                        <option value="">-- Lọc theo tất cả chức vụ --</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">🔍 Tìm kiếm</button>
                </div>
            </form>
        </div>
    </div>

    <div class="mb-3 d-flex justify-content-between align-items-center">
        <a asp-action="Create" class="btn btn-success">➕ Khởi Tạo Tài Khoản Mới</a>
        <span class="text-muted">Tổng số bản ghi: @Model.Count()</span>
    </div>

    <table class="table table-bordered table-striped align-middle">
        <thead class="table-dark">
            <tr>
                <th>Mã TK</th>
                <th>Tên Đăng Nhập</th>
                <th>Email Hệ Thống</th>
                <th>Số Điện Thoại</th>
                <th>Phân Quyền</th>
                <th>Trạng Thái</th>
                <th class="text-center">Hành Động</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" class="text-center text-danger font-weight-bold">Không tìm thấy tài khoản nhân viên nào khớp với tiêu chí!</td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.AccountId</td>
                        <td><strong>@item.Username</strong></td>
                        
                        @* Hiển thị Email thô, hệ thống tự động kiểm tra tính immutability ở controller (BR-10) *@
                        <td>@item.Email</td>
                        
                        @* BR-12: Số điện thoại hiển thị ở đây đã được Controller che bằng dấu hoa thị (*) *@
                        <td>@item.Phone</td>
                        
                        <td>
                            <span class="badge bg-info text-dark">@item.Role.RoleName</span>
                        </td>
                        <td>
                            @if (item.Status == "Active")
                            {
                                <span class="badge bg-success">Đang Hoạt Động</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Bị Vô Hiệu Hóa</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.AccountId" class="btn btn-sm btn-warning">✏️ Sửa</a>
                            
                            <a asp-action="Details" asp-route-id="@item.AccountId" class="btn btn-sm btn-info">👁️ Xem</a>
                            
                            @if (item.Status == "Active")
                            {
                                <form asp-action="Delete" asp-route-id="@item.AccountId" method="post" class="d-inline" 
                                      onsubmit="return confirm('Bạn có chắc chắn muốn vô hiệu hóa tài khoản này không? Data sẽ chuyển về Inactive để giữ Audit Log.');">
                                    <button type="submit" class="btn btn-sm btn-danger">🔒 Khóa</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>